# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/agent_scale
# Local PostgreSQL usually uses disable. Managed PostgreSQL/Supabase direct connections
# often require require or verify-full.
DATABASE_SSL=disable

# App — use BASE_URL for Docker/reverse-proxy deployments (runtime env var).
# NEXT_PUBLIC_BASE_URL is only effective at build time.
BASE_URL=http://localhost:3000
